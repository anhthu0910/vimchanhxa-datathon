    "# -------- test -------------------------------------\n",
    "\n",
    "# ======================\n",
    "# 1. LOAD DATA\n",
    "# ======================\n",
    "con = get_connection()\n",
    "\n",
    "orders = con.execute(\"SELECT * FROM orders\").df()\n",
    "print(\"--- DANH SÁCH BẢNG TRONG DATABASE ---\")\n",
    "tables = con.execute(\"SHOW TABLES\").df()\n",
    "order_items = con.execute(\"SELECT * FROM order_items\").df()\n",
    "products = con.execute(\"SELECT * FROM products\").df()\n",
    "traffic = con.execute(\"SELECT * FROM web_traffic\").df()\n",
    "promotions = con.execute(\"SELECT * FROM promotions\").df()\n",
    "inventory = con.execute(\"SELECT * FROM inventory\").df()\n",
    "\n",
    "# ======================\n",
    "# 2. PREPROCESS\n",
    "# ======================\n",
    "\n",
    "# Convert date\n",
    "orders['order_date'] = pd.to_datetime(orders['order_date'])\n",
    "traffic['date'] = pd.to_datetime(traffic['date'])\n",
    "promotions['start_date'] = pd.to_datetime(promotions['start_date'])\n",
    "promotions['end_date'] = pd.to_datetime(promotions['end_date'])\n",
    "inventory['snapshot_date'] = pd.to_datetime(inventory['snapshot_date'])\n",
    "\n",
    "# ======================\n",
    "# 3. BUILD BASE TABLE\n",
    "# ======================\n",
    "\n",
    "# --- Revenue + Orders ---\n",
    "df_orders = orders.groupby('order_date').agg({\n",
    "    'order_id': 'nunique',\n",
    "    'revenue': 'sum'\n",
    "}).rename(columns={\n",
    "    'order_id': 'num_orders',\n",
    "    'revenue': 'revenue'\n",
    "}).reset_index()\n",
    "\n",
    "# --- Order items ---\n",
    "df_items = order_items.groupby('date').agg({\n",
    "    'quantity': 'sum',\n",
    "    'price': 'mean'\n",
    "}).rename(columns={\n",
    "    'quantity': 'total_quantity',\n",
    "    'price': 'avg_price'\n",
    "}).reset_index()\n",
    "\n",
    "# --- Traffic ---\n",
    "df_traffic = traffic.groupby('date').agg({\n",
    "    'sessions': 'sum',\n",
    "    'users': 'sum',\n",
    "    'pageviews': 'sum'\n",
    "}).reset_index()\n",
    "\n",
    "# --- Promotions ---\n",
    "df_promo = promotions.groupby('date').agg({\n",
    "    'discount': 'mean',\n",
    "    'promo_id': 'nunique'\n",
    "}).rename(columns={\n",
    "    'discount': 'avg_discount',\n",
    "    'promo_id': 'num_promos'\n",
    "}).reset_index()\n",
    "\n",
    "# --- Inventory (forward fill monthly → daily)\n",
    "inventory = inventory.sort_values('date')\n",
    "inventory = inventory.set_index('date').resample('D').ffill().reset_index()\n",
    "\n",
    "df_inventory = inventory.groupby('date').agg({\n",
    "    'stock': 'mean',\n",
    "    'stockout_flag': 'mean'\n",
    "}).rename(columns={\n",
    "    'stock': 'avg_stock',\n",
    "    'stockout_flag': 'stockout_rate'\n",
    "}).reset_index()\n",
    "\n",
    "# ======================\n",
    "# 4. MERGE ALL\n",
    "# ======================\n",
    "df = df_orders.merge(df_items, on='date', how='left')\n",
    "df = df.merge(df_traffic, on='date', how='left')\n",
    "df = df.merge(df_promo, on='date', how='left')\n",
    "df = df.merge(df_inventory, on='date', how='left')\n",
    "\n",
    "# Fill NA\n",
    "df = df.fillna(0)\n",
    "\n",
    "# ======================\n",
    "# 5. TIME FEATURES\n",
    "# ======================\n",
    "df['day_of_week'] = df['date'].dt.dayofweek\n",
    "df['month'] = df['date'].dt.month\n",
    "df['week_of_year'] = df['date'].dt.isocalendar().week.astype(int)\n",
    "\n",
    "# ======================\n",
    "# 6. LAG FEATURES\n",
    "# ======================\n",
    "lags = [1, 7, 14, 28]\n",
    "\n",
    "for lag in lags:\n",
    "    df[f'revenue_lag_{lag}'] = df['revenue'].shift(lag)\n",
    "\n",
    "# ======================\n",
    "# 7. ROLLING FEATURES\n",
    "# ======================\n",
    "df['rolling_mean_7'] = df['revenue'].shift(1).rolling(7).mean()\n",
    "df['rolling_std_7'] = df['revenue'].shift(1).rolling(7).std()\n",
    "\n",
    "df['rolling_mean_30'] = df['revenue'].shift(1).rolling(30).mean()\n",
    "\n",
    "# ======================\n",
    "# 8. TRAFFIC LAG (VERY IMPORTANT)\n",
    "# ======================\n",
    "for lag in [1, 3, 7]:\n",
    "    df[f'sessions_lag_{lag}'] = df['sessions'].shift(lag)\n",
    "\n",
    "# ======================\n",
    "# 9. CLEAN\n",
    "# ======================\n",
    "df = df.dropna().reset_index(drop=True)\n",
    "\n",
    "# ======================\n",
    "# 10. SAVE\n",
    "# ======================\n",
    "# df.to_csv(\"feature_engineer.csv\", index=False)\n",
    "df.head(10)\n",
    "\n",
    "print(\"✅ Feature engineering completed! Saved to feature_engineer.csv\")"
   ]
  },
